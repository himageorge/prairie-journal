{
  "name": "Prairie Journal",
  "description": "Learn from your PrairieLearn mistakes",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": ["storage", "activeTab", "sidePanel"],
  "action": {
    "default_title": "Prairie Journal",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "content_security_policy": {
    "script-src": ["'self'", "https://cdnjs.cloudflare.com"]
  }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "host_permissions": [
    "*://*.prairielearn.com/*",
    "*://*.prairielearn.org/*"
  ],

    "content_scripts": [{
    "matches": [
        "https://us.prairielearn.com/*",
        "https://ca.prairielearn.com/*",
        "https://*.prairielearn.com/*"
    ],
    "js": ["content.js"],
    "run_at": "document_start"
    }],
  "background": {
    "service_worker": "background.js"
  }

}